# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# DRY_RUN=true simulates everything (safe, no funds touched, no RPC needed).
# Set to false ONLY after a funded wallet + RPC are configured and validated.
DRY_RUN=true

# ── Solana ───────────────────────────────────────────────────────────────────
# Paid RPC recommended (Helius/QuickNode).
RPC_URL=

# The OPERATING wallet — must be the $AMENS token CREATOR wallet (it claims the
# creator fees). base58 secret key OR a JSON byte array.
# In DRY_RUN you can leave this blank — an ephemeral keypair is generated.
WALLET_PRIVATE_KEY=

# The $AMENS token mint (your pump.fun token), and (optional) its PumpSwap pool.
TOKEN_MINT=
PUMPSWAP_POOL_ID=

# ── The flywheel ─────────────────────────────────────────────────────────────
# Every tick the bot claims whatever creator fees accrued, then:
#   BUYBACK_PCT% of the SOL buys back $AMENS
#   of the tokens bought: ANSEM_PCT% → REWARD_WALLET, BURN_PCT% → burned
#   the rest (25% of the SOL, 25% of the tokens) stays in the operating wallet
#   (marketing budget + transaction fees)
POLL_SCHEDULE=*/5 * * * *         # every 5 minutes
BUYBACK_PCT=75                    # % of each claim → buy back $AMENS
ANSEM_PCT=70                      # % of bought tokens → the Ansem wallet
BURN_PCT=5                        # % of bought tokens → burned on-chain
REWARD_WALLET=GV6UUmNxz2RpKxmNAPadYKb7uQpszwqQAu3qLJxVdC52
TOKEN_SYMBOL=AMENS

# DRY_RUN only: simulated SOL accrued to the fee vault per tick (so cycles run).
DRY_RUN_FEE_PER_POLL=0.4
# DRY_RUN only: simulate a GRADUATED token (exercises the AMM path).
SIMULATE_GRADUATED=false

# ── On-chain execution (live mode only) ──────────────────────────────────────
SLIPPAGE_PCT=5                    # PumpSwap AMM slippage, percent
CURVE_SLIPPAGE_PCT=5              # bonding-curve buy slippage, percent
PRIORITY_FEE_MICROLAMPORTS=50000  # compute-unit price for landing txs under load
COMPUTE_UNIT_LIMIT=200000         # compute-unit limit per transaction

# ── Storage (MongoDB) ────────────────────────────────────────────────────────
# Local mongod, or a MongoDB Atlas SRV URI (mongodb+srv://user:pass@cluster/...).
MONGODB_URI=
MONGODB_DB=amens

# ── Frontend / CORS ──────────────────────────────────────────────────────────
# Comma-separated allowlist of browser origins that may call the API.
CORS_ORIGINS=

# Secret protecting POST /api/run|pause|resume. Blank = open (dev only).
# In production set a long random string; send it as header x-api-key: <key>.
API_KEY=
